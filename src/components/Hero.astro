---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import CEOImage from "@assets/images/ceo.webp";
import Button from "./Button.astro";
import ButtonLink from "./ButtonLink.astro";
import ArrowRight from "../icons/arrow--right.svg";
---

<section class="hero">
  <div class="hero-content">
    <h1>Empowering Your Business Growth</h1>
    <p>
      Discover tailored strategies and expert insights to take your business to
      the next level. Let us help you navigate challenges and achieve
      sustainable success.
    </p>
    <Button text="Book a Meeting" variant="yellow" />
    <ButtonLink text="Learn more" href="/services" icon={ArrowRight} />
  </div>
  <Image src={CEOImage} alt="CEO" />

  <Services />
</section>

<style>
  @layer components {
    .hero {
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full;
      grid-template-rows: auto 1fr;

      h1 {
        font-size: var(--step-3);
        max-width: 15ch;
      }

      p {
        max-width: 50ch;
        padding-bottom: 1em;
      }
    }

    .hero-content {
      grid-column: content-start / content-mid;
      grid-row: 1 / 2;
      padding-block: 5rem;
    }

    .hero img {
      grid-column: content-mid / full-end;
      width: 100%;
      height: auto;
      grid-row: 1 / 2;
    }

    .hero :global(.services) {
      grid-column: content-start / content-end;
      grid-row: 2;

      transform: translateY(-50%);
      z-index: 2;
    }
  }
</style>
