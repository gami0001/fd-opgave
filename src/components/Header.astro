---
import Button from "./Button.astro";
import Logo from "../icons/AskExperts.svg";
import DashboardLogin from "./DashboardLogin.astro";
import "../styles/tokens.css";
---

<header class="breakout">
  <div class="header_flex">
    <a href="/">
      <Logo />
    </a>

    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/case">Case Study</a></li>
        <li><a href="/team">Team</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>

    <Button id="nav-btn" popovertarget="pop" text="Login" />
  </div>
</header>

<div id="pop" popover>
  <DashboardLogin />
</div>

<style>
  @layer components {
    .header_flex {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      padding: 15px 30px;

      a {
        display: flex;
        align-items: center;

        svg {
          width: 120px;
          height: auto;
        }
      }

      nav {
        ul {
          display: flex;
          list-style: none;
          gap: 30px;

          li {
            a {
              text-decoration: none;
              color: var(--color-neutrals-50);
              font-weight: 500;
              transition: color 0.3s;
            }
          }
        }
      }
    }
    /* ✅ Popover CSS */
    [popovertarget] {
      anchor-name: --nav-btn;
    }

    [popover] {
      position: absolute;
      position-anchor: --nav-btn;
      position-area: bottom span-left; /* under knappen, til højre */
      justify-self: anchor-center; /* centreret ift. anchor */
    }

    #pop {
      border-radius: var(--border-radius-0);
      background-color: var(--color-neutrals-200);
      border: none;
      box-shadow: 0 3px 10px rgba(0, 0, 0, 0.3);
    }
  }
</style>
