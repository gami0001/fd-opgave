---
import DynamicIcon from "./helpers/DynamicIcon.astro";
const { data } = Astro.props;
---

<section class="team">
  {
    data.map((employee: any) => (
      <div class="card-wrapper">
        <article class="card">
          <img class="card-img" src={employee.img} alt={employee.name} />

          <div class="card-content">
            <h3>{employee.name}</h3>
            <h4 class="title">{employee.title}</h4>
            <p>{employee.description}</p>

            <div class="socials">
              {employee.social_links.map((social: any) => (
                <a href={social.url} aria-label={social.platform}>
                  <DynamicIcon class="icon" name={social.icon} />
                </a>
              ))}
            </div>
          </div>
        </article>
      </div>
    ))
  }
</section>

<style>
  @layer component {
    .team {
      grid-column: content-start / content-end;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      grid-template-rows: auto auto auto 1fr auto;
      gap: 2rem;

      .card-wrapper {
        container: card / inline-size;
      }
      .card {
        display: grid;
      }

      .card-img {
        border-radius: var(--border-radius-0);
        width: 100%;
        display: block;
      }

      .card-content {
        text-align: center;
      }

      h3 {
        font-size: var(--step-1);
        font-weight: 600;
      }

      h4 {
        display: inline-block;
        padding: 5px 20px;
        background-color: var(--color-neutrals-900);
        color: var(--color-neutrals-50);
        border-radius: var(--border-radius-1);
        font-size: var(--step--2);
        font-weight: 600;
      }

      p {
        font-size: var(--step--2);
        color: var(--color-neutrals-700);
      }

      .socials {
        display: flex;
        justify-content: center;
        gap: 25px;
      }

      .icon {
        width: 25px;
        height: auto;
      }

      @container card (width > 300px) {
        .card {
          grid-template-columns: 120px 1fr;
          align-items: center;
        }

        .socials {
          display: none;
        }

        h4 {
          color: var(--color-neutrals-50);
          font-size: var(--step--2);
        }

        .card-content {
          text-align: left;
          margin-left: 10px;
        }
      }
    }
  }
</style>
