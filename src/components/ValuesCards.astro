---
const { icon: Icon, arrowIcon: ArrowIcon, title, description } = Astro.props;
---

<article class="values_card">
  <div class="icon">
    <Icon />
  </div>
  <h3>{title}</h3>
  <p class="description">{description}</p>
  <p class="cta">
    Read more <ArrowIcon />
  </p>
</article>

<style>
  .values_card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }

  .icon {
    width: 48px;
    height: 48px;
  }

  .cta {
    display: flex;
    align-items: center;
    font-weight: 500;
    cursor: pointer;
    gap: 0.5rem;
    color: var(--color-blue-700);
  }

  .cta svg {
    width: 1em;
    height: 1em;
  }
</style>
