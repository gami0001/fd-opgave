---
const { icon: Icon, arrowIcon: ArrowIcon, title, description } = Astro.props;
import "../styles/tokens.css";
---

<article class="values_card">
  <div class="icon">
    <Icon />
  </div>
  <h3>{title}</h3>
  <p class="description">{description}</p>
  <p class="cta">
    Read more <ArrowIcon />
  </p>
</article>

<style>
  .values_card {
    background: var(--color-neutrals-50);
    color: var(--color-neutrals-900);
    border-radius: 12px;
    padding: var(--space-s);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }

  .icon {
    width: 56px;
    height: 56px;

    background: var(--color-neutrals-900);
    border-radius: 50%;

    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cta {
    display: flex;
    align-items: center;
    font-weight: 500;
    cursor: pointer;
    gap: 0.5rem;
    color: var(--color-blue-700);
  }

  .cta svg {
    width: 1em;
    height: 1em;
  }

  .icon svg {
    width: 22px;
    height: 22px;
    color: var(--color-neutrals-50);
  }
</style>
