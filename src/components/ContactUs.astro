---
import Phone from "../icons/phone.svg";
import Clock from "../icons/clock.svg";
import Pin from "../icons/pin.svg";
---

<section class="contact">
  <div class="container">
    <div>
      <p class="first-p">PROCESS</p>
      <h2>Contact Us. It's Easy.</h2>
      <p class="more_info">
        Leverage agile frameworks to provide a robust synopsis for high level
        overviews. Iterative approaches to corporate strategy foster
        collaborative.
      </p>

      <div class="contact-info">
        <span class="phone"><Phone /></span>
        <div>
          <p>Call Today</p>
          <p class="bold">+1 800 100 900</p>
        </div>
      </div>

      <div class="contact-info">
        <span class="clock"><Clock /></span>
        <div>
          <p>Monday To Friday</p>
          <p class="bold">9AM - 5PM</p>
        </div>
      </div>

      <div class="contact-info">
        <span class="pin"><Pin /></span>
        <div>
          <p>USA Office</p>
          <p class="bold">195 Devonshire St Boston, MA 02110</p>
        </div>
      </div>
    </div>

    <div class="image-wrapper">
      <img src="images/Image1.webp" alt="billede af kvinde" />
      <img
        src="/images/Image2.webp"
        alt="billede af 2 kvinder der arbejder sammen"
      />
      <img src="/images/Image3.webp" alt="billede af hænder" />
      <div class="green-box"></div>
    </div>
  </div>
</section>

<style>
  @layer component {
    .contact {
      grid-column: content-start / content-end;
      padding-block: 8rem;

      .container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;

        .first-p {
          letter-spacing: 0.1em;
          text-transform: uppercase;
        }

        h2 {
          font-size: var(--step-3);
          font-weight: 600;
          margin-bottom: var(--space-xs);
        }

        .more_info {
          max-width: 40ch;
          color: var(--color-neutrals-700);
        }
      }

      .contact-info {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1rem;
        align-items: center;
        margin-top: 1.5rem;

        :first-child {
          color: var(--color-neutrals-700);
        }

        :last-child {
          font-size: var(--step--1);
          font-weight: 600;
        }
      }

      .phone {
        width: 40px;
        height: 40px;
        color: var(--color-yellow-600);
        background-color: var(--color-yellow-400);
        padding: 10px;
        border-radius: var(--border-radius-3);
      }

      .clock {
        width: 40px;
        height: 40px;
        color: var(--color-green-600);
        background-color: var(--color-green-400);
        padding: 10px;
        border-radius: var(--border-radius-3);
      }

      .pin {
        width: 40px;
        height: 40px;
        color: var(--color-neutrals-900);
        background-color: var(--color-neutrals-200);
        padding: 12px;
        border-radius: var(--border-radius-3);
      }

      .image-wrapper {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        grid-template-rows: repeat(2, 1fr);
        gap: 0.8rem;
        position: relative;
      }

      .image-wrapper img:first-child {
        grid-column: 1 / 2;
        grid-row: 1 / 3;
        border-radius: var(--border-radius-0);
      }

      .image-wrapper img:nth-child(2) {
        grid-column: 2 / 3;
        grid-row: 1 / 2;
        border-radius: var(--border-radius-0);
      }

      .image-wrapper img:nth-child(3) {
        grid-column: 2 / 3;
        grid-row: 2 / 3;
        border-radius: var(--border-radius-0);
      }

      .green-box {
        position: absolute;
        bottom: -15px;
        left: -30px;
        width: 200px;
        height: 100px;
        background: var(--color-green-400);
        border-radius: var(--border-radius-0);
        z-index: -1;
      }
    }
  }
</style>
