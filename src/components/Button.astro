---
const {
  text = "Button",
  type = "button",
  variant = "default",
  ...props
} = Astro.props;
---

<button
  type={type}
  class={`btn 
    ${variant === "yellow" ? "btn-yellow" : ""} 
    ${variant === "dark" ? "btn-dark" : ""}`}
  {...props}
>
  {text}
</button>

<style>
  @layer components {
    .btn {
      padding: 5px 24px;
      border-radius: var(--border-radius-1);
      background-color: var(--color-neutrals-50);
      border: none;
      cursor: pointer;
      font-weight: 500;
      color: var(--color-neutrals-900);

      &:hover {
        background-color: color-mix(
          in oklab,
          var(--color-neutrals-50),
          #000 20%
        );
      }

      &:active {
        background-color: color-mix(
          in oklab,
          var(--color-neutrals-50),
          #000 20%
        );
      }
    }

  .btn.btn-dark {
  background-color: var(--color-neutrals-900);
  color: var(--color-neutrals-50);

  &:hover {
    background-color: color-mix(
      in oklab,
      var(--color-neutrals-900),
      #fff 15%
    );
  }

  &:active {
    background-color: color-mix(
      in oklab,
      var(--color-neutrals-900),
      #fff 25%
    );
  }
}
    }

    .btn-yellow {
      background-color: var(--color-yellow-500);

      &:hover {
        background-color: color-mix(
          in oklab,
          var(--color-yellow-500),
          #000 10%
        );
      }
      &:active {
        background: color-mix(in oklab, var(--color-yellow-500), #000 20%);
      }
    }
  }
</style>
