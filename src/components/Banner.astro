---
import "../styles/tokens.css";

const {
  eyebrow = "Eyebrow",
  title = "Title",
  text = "Text content...",
  line,
} = Astro.props;
---

<section class={`banner_section ${line ? `line-${line}` : ""}`}>
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <p>{text}</p>
</section>

<style>
  .banner_section {
    background: var(--color-neutrals-50);
    color: var(--color-neutrals-900);

    display: grid;
    grid-template-columns: subgrid;
    grid-column: full;

    padding-block: 4rem;
    text-align: center;
  }

  .banner_section > * {
    grid-column: content;
    margin-inline: auto;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: var(--step--2);
    margin-bottom: var(--space-xs);
  }

  h1 {
    font-size: var(--step-4);
    margin-bottom: var(--space-s);

    display: inline-block;
    position: relative;
    z-index: 0;
  }

  h1::after {
    content: "";
    position: absolute;

    left: 0;
    right: 0;

    bottom: 0.09em;
    height: 0.1em;

    background: var(--color-yellow-600);

    z-index: -1;
  }

  p {
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    max-width: 60ch;
  }
</style>
